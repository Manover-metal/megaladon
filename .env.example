APP_NAME=Megaladon
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=megaladon
DB_USERNAME=megaladon
DB_PASSWORD=secret

CACHE_DRIVER=redis
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

# Путь к service-account JSON Firebase (не коммитим сам файл).
FIREBASE_CREDENTIALS=storage/app/firebase/service-account.json

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
